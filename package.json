{
  "name": "pic-sure-frontend",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean": "pnpm run format && pnpm run lint",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "pnpm run test:vitest && pnpm run test:integration",
    "test:vitest": "vitest run tests/unit tests/component",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:integration": "playwright test",
    "playwright": "playwright test --ui",
    "playwright:dev": "PLAYWRIGHT_DEV=1 playwright test --ui",
    "precommit": "pnpm run format && pnpm run lint && pnpm run check && pnpm run test"
  },
  "type": "module",
  "dependencies": {
    "@dnd-kit-svelte/svelte": "^0.1.5",
    "@dnd-kit-svelte/utilities": "^0.0.11",
    "@dnd-kit/abstract": "^0.4.0",
    "@dnd-kit/helpers": "^0.4.0",
    "@floating-ui/dom": "^1.7.6",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@skeletonlabs/floating-ui-svelte": "^0.3.9",
    "@skeletonlabs/skeleton": "^3.2.0",
    "@skeletonlabs/skeleton-svelte": "^1.5.1",
    "@vincjo/datatables": "^2.8.0",
    "auth0-js": "^10.2.0",
    "dompurify": "^3.4.3",
    "driver.js": "^1.4.0",
    "gtagjs": "^0.0.10",
    "plotly.js-basic-dist-min": "^3.5.1",
    "quill": "^2.0.3",
    "shiki": "^4.0.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/auth0-js": "^9.21.6",
    "@types/node": "25.7.0",
    "@types/plotly.js-basic-dist-min": "^2.12.4",
    "@types/quill": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "5.56.4",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
